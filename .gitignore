# PAGE: CHAT
# ══════════════════════════════════════════════════════════════════════════════
def page_chat():
    col1, col2, col3 = st.columns([4,1,1])
    with col1:
        neon_header("◈ AI CHAT", "Gemini 2.0 Flash · Context-aware · Real-time")
    with col2:
        if st.button("CLEAR", use_container_width=True):
            st.session_state.chat_messages = []
            st.session_state.gemini_history = []
            st.rerun()
    with col3:
        if st.session_state.chat_messages:
            md = "\n\n---\n\n".join([f"**{m['role'].upper()}**\n\n{m['content']}" for m in st.session_state.chat_messages])
            st.download_button("EXPORT", md, "12six-chat.md", "text/markdown", use_container_width=True)

    st.markdown("<div style='border-top:1px solid rgba(0,212,255,0.12);margin-bottom:1rem;'></div>", unsafe_allow_html=True)

    for msg in st.session_state.chat_messages:
        with st.chat_message(msg["role"], avatar="◈" if msg["role"] != "user" else "◉"):
            st.markdown(msg["content"])

    if not is_paid() and st.session_state.usage_seconds >= FREE_TIER_SECONDS:
        st.error("⊘ DAILY LIMIT REACHED — Upgrade to Silver for unlimited access.")
        if st.button("◇ VIEW PRICING", type="primary"):
            go("pricing")
        return

    if prompt := st.chat_input("// Enter your query..."):
        st.session_state.chat_messages.append({"role":"user","content":prompt})
        with st.chat_message("user", avatar="◉"):
            st.markdown(prompt)
        with st.chat_message("assistant", avatar="◈"):
            with st.spinner(""):
                start = time.time()
                reply = ask_gemini(prompt)
                elapsed = int(time.time() - start)
                if not is_paid():
                    st.session_state.usage_seconds += elapsed
            st.markdown(reply)
            st.session_state.chat_messages.append({"role":"assistant","content":reply})
            if not is_paid():
                rem = rem_min()
                c = "#ff4466" if rem < 30 else "#f0c060" if rem < 60 else "#00d4ff"
                st.markdown(f"<div style='color:{c};font-family:\"Share Tech Mono\",monospace;font-size:0.68rem;margin-top:0.3rem;'>// {rem} FREE MINUTES REMAINING</div>", unsafe_allow_html=True)

# ══════════════════════════════════════════════════════════════════════════════
# PAGE: APP BUILDER (free, ChatGPT's idea — fully rebuilt)
# ══════════════════════════════════════════════════════════════════════════════
def page_builder():
    neon_header("⬢ AI APP BUILDER", "Autonomous project generation · Full files · Free for all operators")

    idea = st.text_area("// Describe your application", height=130,
        placeholder="e.g. A CLI tool that scrapes product prices and saves to CSV with charts")

    col1, col2 = st.columns(2)
    with col1:
        tech = st.selectbox("// Tech Stack", [
            "Python (CLI / Script)",
            "Python + Flask (Web App)",
            "Python + FastAPI",
            "React + Node.js",
            "Next.js + TypeScript",
            "Streamlit App",
            "Django",
            "MERN Stack",
        ])
    with col2:
        st.markdown("<div style='height:1.9rem'></div>", unsafe_allow_html=True)
        build_btn = st.button("⬢ BUILD PROJECT", use_container_width=True, type="primary")

    if build_btn:
        if not idea.strip():
            st.warning("// Provide project description first.")
            return
        with st.spinner("// 12six AI is building your project..."):
            data = gen_app(idea, tech)

        files = data.get("files", {})
        plan  = data.get("plan",  [])

        if plan:
            section_label("BUILD PLAN")
            for step in plan:
                st.markdown(f"<div style='color:#e2f0ff;font-family:Rajdhani,sans-serif;font-size:0.95rem;padding:2px 0;'>◦ {step}</div>", unsafe_allow_html=True)
            st.markdown("<div style='height:0.8rem'></div>", unsafe_allow_html=True)

        if files:
            st.session_state.project_files = files
            st.success(f"// {len(files)} files generated. Project saved to session.")

            buf = io.BytesIO()
            with zipfile.ZipFile(buf, "w", zipfile.ZIP_DEFLATED) as z:
                for fname, content in files.items():
                    z.writestr(fname, content)
            st.download_button("⬇ DOWNLOAD PROJECT ZIP", buf.getvalue(),
                "12six_project.zip", "application/zip", use_container_width=True)

            col1, col2 = st.columns(2)
            with col1:
                if st.button("▶ RUN THIS PROJECT", use_container_width=True, type="primary"):
                    go("runner")
            with col2:
                if st.button("🐞 DEBUG THIS PROJECT", use_container_width=True):
                    go("debugger")

            with st.expander(f"// PREVIEW — {len(files)} FILES"):
                for fname, content in files.items():
                    st.markdown(f"**`{fname}`**")
                    ext = fname.split(".")[-1] if "." in fname else "text"
                    st.code(content[:3000], language=ext)
                    if len(content) > 3000:
                        st.caption(f"... {len(content):,} total chars")
        else:
            st.error("// Generation failed. Try rephrasing your description.")

# ══════════════════════════════════════════════════════════════════════════════
# PAGE: RUN PROJECT (ChatGPT's idea — security fixed)
# ══════════════════════════════════════════════════════════════════════════════
def page_runner():
    neon_header("▶ RUN PROJECT", "Execute generated code · Sandboxed · 10s timeout · Path-safe")

    files = st.session_state.project_files

    if not files:
        st.markdown(f"""
        <div style="background:rgba(0,212,255,0.04);border:1px solid rgba(0,212,255,0.1);
                    border-radius:10px;padding:2rem;text-align:center;">
            <div style="font-family:'Orbitron',sans-serif;color:#4a6080;font-size:0.85rem;margin-bottom:0.5rem;">
                // NO PROJECT LOADED
            </div>
            <div style="color:#4a6080;font-family:'Rajdhani',sans-serif;font-size:0.9rem;">
                Build a project first using the AI App Builder module.
            </div>
        </div>
        """, unsafe_allow_html=True)
        if st.button("⬢ GO TO APP BUILDER", type="primary"):
            go("builder")
        return

    has_main = "main.py" in files
    main_color = "#00ff88" if has_main else "#ff4466"
    main_status = "✦ FOUND" if has_main else "⚠ NOT FOUND"

    st.markdown(f"""
    <div style="background:rgba(0,255,136,0.04);border:1px solid rgba(0,255,136,0.15);
                border-radius:10px;padding:1rem;margin-bottom:1rem;">
        <div style="color:#00ff88;font-family:'Share Tech Mono',monospace;font-size:0.75rem;">
            // PROJECT LOADED: {len(files)} files · main.py
            <span style="color:{main_color};">{main_status}</span>
        </div>
    </div>
    """, unsafe_allow_html=True)

    with st.expander("// VIEW PROJECT FILES"):
        for fname, content in files.items():
            st.markdown(f"**`{fname}`**")
            ext = fname.split(".")[-1] if "." in fname else "text"
            st.code(content[:2000], language=ext)
            if len(content) > 2000:
                st.caption(f"... {len(content):,} total chars")

    col1, col2, col3 = st.columns(3)
    with col1:
        run_btn = st.button("▶ EXECUTE main.py", use_container_width=True, type="primary")
    with col2:
        if st.button("🐞 DEBUG PROJECT", use_container_width=True):
            go("debugger")
    with col3:
        if st.button("⊘ CLEAR PROJECT", use_container_width=True):
            st.session_state.project_files = {}
            st.rerun()

    if run_btn:
        if not has_main:
            st.error("// No main.py found. Make sure your project has a main.py entry point.")
            return
        with st.spinner("// Executing in sandbox..."):
            result = safe_run(files)

        if result["success"]:
            st.success("// Execution completed successfully.")
        else:
            st.error("// Execution failed.")

        if result["stdout"]:
            section_label("OUTPUT", "#00ff88")
            st.code(result["stdout"], language="text")

        if result["stderr"]:
            section_label("ERRORS", "#ff4466")
            st.code(result["stderr"], language="text")
            if st.button("🐞 AUTO-FIX WITH AI", type="primary", use_container_width=True):
                with st.spinner("// Analyzing errors..."):
                    fix = fix_code_ai(
                        files.get("main.py","") + "\n\n# RUNTIME ERRORS:\n" + result["stderr"]
                    )
                section_label("FIXED CODE", "#00ff88")
                st.code(fix.get("fixed_code",""), language="python")
                section_label("EXPLANATION")
                st.markdown(fix.get("explanation",""))
                if fix.get("errors_found"):
                    section_label("ERRORS FOUND", "#ff4466")
                    for err in fix["errors_found"]:
                        st.markdown(f"◦ {err}")

# ══════════════════════════════════════════════════════════════════════════════
# PAGE: DEBUGGER (ChatGPT's render_debugger — fully rebuilt with proper JSON)
# ══════════════════════════════════════════════════════════════════════════════
def page_debugger():
    neon_header("🐞 CODE DEBUGGER", "Paste broken code · AI analyzes errors · Returns fixed version")

    tab1, tab2, tab3 = st.tabs(["FIX CODE", "EXPLAIN CODE", "OPTIMIZE CODE"])

    with tab1:
        code = st.text_area("// Paste your broken code", height=280,
            placeholder="# Paste any broken Python, JS, or other code here...\n# 12six AI will find and fix every error.",
            key="debug_fix")
        col1, col2 = st.columns(2)
        with col1:
            fix_btn = st.button("🐞 ANALYZE & FIX", use_container_width=True, type="primary", key="btn_fix")
        with col2:
            if st.session_state.project_files and st.button("📂 LOAD FROM PROJECT", use_container_width=True, key="btn_load"):
                main = st.session_state.project_files.get("main.py","")
                st.session_state["debug_prefill"] = main
                st.rerun()

        if fix_btn and code.strip():
            with st.spinner("// Analyzing your code..."):
                result = fix_code_ai(code)

            section_label("FIXED CODE", "#00ff88")
            st.code(result.get("fixed_code", code), language="python")

            if result.get("errors_found"):
                section_label("ERRORS FOUND", "#ff4466")
                for err in result["errors_found"]:
                    st.markdown(f"<div style='color:#ff4466;font-family:Rajdhani,sans-serif;font-size:0.9rem;padding:2px 0;'>◦ {err}</div>", unsafe_allow_html=True)

            section_label("EXPLANATION")
            st.markdown(result.get("explanation",""))

            # Update project if it came from there
            if "main.py" in st.session_state.project_files and code.strip() == st.session_state.project_files.get("main.py","").strip():
                if st.button("✦ UPDATE PROJECT WITH FIX", type="primary"):
                    st.session_state.project_files["main.py"] = result.get("fixed_code", code)
                    st.success("// Project main.py updated with fixed code.")

        elif fix_btn:
            st.warning("// Paste some code first.")

    with tab2:
        code2 = st.text_area("// Code to explain", height=280,
            placeholder="# Paste any code and 12six AI will explain it clearly...", key="debug_explain")
        if st.button("◈ EXPLAIN THIS CODE", use_container_width=True, type="primary", key="btn_explain"):
            if code2.strip():
                with st.spinner("// Reading your code..."):
                    explanation = ask_gemini(
                        f"Explain this code clearly and thoroughly. Break it down section by section.\n\n```\n{code2}\n```"
                    )
                section_label("CODE EXPLANATION")
                st.markdown(explanation)
            else:
                st.warning("// Paste some code first.")

    with tab3:
        code3 = st.text_area("// Code to optimize", height=280,
            placeholder="# Paste working code and 12six AI will make it faster and cleaner...", key="debug_optimize")
        if st.button("⬢ OPTIMIZE THIS CODE", use_container_width=True, type="primary", key="btn_opt"):
            if code3.strip():
                with st.spinner("// Optimizing..."):
                    opt = ask_gemini(
                        f"Optimize this code for performance, readability and best practices. Show the improved version with explanations.\n\n```\n{code3}\n```"
                    )
                section_label("OPTIMIZED CODE")
                st.markdown(opt)
            else:
                st.warning("// Paste some code first.")

