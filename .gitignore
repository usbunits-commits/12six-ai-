# PREMIUM CSS
# ══════════════════════════════════════════════════════════════════════════════
st.markdown("""
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap');

:root {
    --cyan:#00d4ff; --cyan2:#00a8cc; --purple:#a855f7; --purple2:#7c3aed;
    --bg:#020408; --bg2:#040810; --bg3:#070d1a; --bg4:#0a1020;
    --border:rgba(0,212,255,0.12); --border2:rgba(0,212,255,0.22);
    --text:#e2f0ff; --muted:#4a6080; --green:#00ff88; --red:#ff4466;
    --gold:#f0c060; --silver:#94c8e8; --diamond:#c0a0e8;
}
*, *::before, *::after { box-sizing:border-box; }
html, body, [class*="css"] {
    font-family:'Rajdhani',sans-serif !important;
    background:var(--bg) !important;
    color:var(--text) !important;
}
::-webkit-scrollbar { width:4px; height:4px; }
::-webkit-scrollbar-track { background:var(--bg); }
::-webkit-scrollbar-thumb { background:linear-gradient(var(--cyan2),var(--purple)); border-radius:2px; }
#MainMenu, footer, header { visibility:hidden; }
.block-container { padding:1.5rem 2rem !important; max-width:1400px !important; }

/* ── Sidebar ── */
section[data-testid="stSidebar"] { background:var(--bg2) !important; border-right:1px solid var(--border) !important; }
section[data-testid="stSidebar"] > div { padding:0 !important; }

/* ── Buttons ── */
.stButton > button {
    background:transparent !important; border:1px solid var(--border2) !important;
    color:var(--muted) !important; border-radius:6px !important;
    font-family:'Rajdhani',sans-serif !important; font-size:0.85rem !important;
    font-weight:600 !important; letter-spacing:0.06em !important;
    transition:all 0.25s ease !important; text-transform:uppercase !important;
}
.stButton > button:hover {
    border-color:var(--cyan) !important; color:var(--cyan) !important;
    background:rgba(0,212,255,0.06) !important;
    box-shadow:0 0 15px rgba(0,212,255,0.15),inset 0 0 15px rgba(0,212,255,0.03) !important;
}
.stButton > button[kind="primary"] {
    background:linear-gradient(135deg,rgba(0,212,255,0.15),rgba(168,85,247,0.15)) !important;
    border:1px solid var(--cyan) !important; color:var(--cyan) !important;
    box-shadow:0 0 20px rgba(0,212,255,0.2) !important;
}
.stButton > button[kind="primary"]:hover {
    background:linear-gradient(135deg,rgba(0,212,255,0.28),rgba(168,85,247,0.28)) !important;
    box-shadow:0 0 30px rgba(0,212,255,0.4),0 0 60px rgba(168,85,247,0.15) !important;
    transform:translateY(-1px) !important; color:#fff !important;
}

/* ── Inputs ── */
.stTextInput input, .stTextArea textarea {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    color:var(--text) !important; border-radius:6px !important;
    font-family:'Share Tech Mono',monospace !important; font-size:0.85rem !important;
    transition:border-color 0.2s !important;
}
.stTextInput input:focus, .stTextArea textarea:focus {
    border-color:var(--cyan) !important;
    box-shadow:0 0 0 2px rgba(0,212,255,0.1),0 0 20px rgba(0,212,255,0.08) !important;
}
.stSelectbox > div > div {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    color:var(--text) !important; font-family:'Share Tech Mono',monospace !important;
}

/* ── Chat ── */
.stChatMessage {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    border-radius:10px !important; margin-bottom:8px !important;
}
.stChatMessage p { font-family:'Rajdhani',sans-serif !important; font-size:1rem !important; }
.stChatInputContainer { background:var(--bg2) !important; border-top:1px solid var(--border) !important; }
.stChatInputContainer textarea {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    color:var(--text) !important; font-family:'Rajdhani',sans-serif !important;
}

/* ── Metrics ── */
[data-testid="stMetric"] {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    border-radius:8px !important; padding:1.2rem !important;
    position:relative !important; overflow:hidden !important;
}
[data-testid="stMetric"]::before {
    content:''; position:absolute; top:0; left:0; right:0; height:1px;
    background:linear-gradient(90deg,transparent,var(--cyan),transparent);
}
[data-testid="stMetricLabel"] {
    color:var(--muted) !important; font-family:'Share Tech Mono',monospace !important;
    font-size:0.65rem !important; letter-spacing:0.12em !important; text-transform:uppercase !important;
}
[data-testid="stMetricValue"] {
    color:var(--cyan) !important; font-family:'Orbitron',sans-serif !important;
    font-size:1.4rem !important; font-weight:700 !important;
}

/* ── Tabs ── */
.stTabs [data-baseweb="tab-list"] { background:transparent !important; border-bottom:1px solid var(--border) !important; }
.stTabs [data-baseweb="tab"] {
    color:var(--muted) !important; font-family:'Rajdhani',sans-serif !important;
    font-size:0.9rem !important; font-weight:600 !important;
    letter-spacing:0.08em !important; text-transform:uppercase !important;
}
.stTabs [aria-selected="true"] { color:var(--cyan) !important; border-bottom:2px solid var(--cyan) !important; }

/* ── Misc ── */
hr { border-color:var(--border) !important; }
.stProgress > div > div {
    background:linear-gradient(90deg,var(--cyan),var(--purple)) !important;
    box-shadow:0 0 10px rgba(0,212,255,0.4) !important;
}
.stInfo    { background:rgba(0,212,255,0.05) !important; border:1px solid rgba(0,212,255,0.2) !important; border-radius:8px !important; }
.stSuccess { background:rgba(0,255,136,0.05) !important; border:1px solid rgba(0,255,136,0.2) !important; border-radius:8px !important; }
.stError   { background:rgba(255,68,102,0.05) !important; border:1px solid rgba(255,68,102,0.2) !important; border-radius:8px !important; }
.stWarning { background:rgba(168,85,247,0.05) !important; border:1px solid rgba(168,85,247,0.2) !important; border-radius:8px !important; }
.streamlit-expanderHeader {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    border-radius:6px !important; color:var(--muted) !important;
    font-family:'Share Tech Mono',monospace !important; font-size:0.8rem !important;
}
code { background:rgba(0,212,255,0.08) !important; color:var(--cyan) !important; border-radius:4px !important; font-family:'Share Tech Mono',monospace !important; }
pre  { background:var(--bg2) !important; border:1px solid var(--border) !important; border-radius:8px !important; }
.stDownloadButton > button {
    background:linear-gradient(135deg,rgba(0,212,255,0.15),rgba(168,85,247,0.15)) !important;
    border:1px solid var(--cyan) !important; color:var(--cyan) !important;
    box-shadow:0 0 20px rgba(0,212,255,0.2) !important;
}
[data-testid="stForm"] {
    background:var(--bg3) !important; border:1px solid var(--border) !important;
    border-radius:10px !important; padding:1.5rem !important;
}

/* ── Animations ── */
@keyframes fadeUp    { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
@keyframes neonPulse { 0%,100%{text-shadow:0 0 7px #00d4ff,0 0 20px #00d4ff,0 0 40px #00d4ff} 50%{text-shadow:0 0 4px #00d4ff,0 0 10px #00d4ff} }
@keyframes shimmer   { 0%{background-position:-200% center} 100%{background-position:200% center} }
@keyframes float     { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
@keyframes borderGlow{ 0%,100%{box-shadow:0 0 5px rgba(0,212,255,0.3)} 50%{box-shadow:0 0 25px rgba(0,212,255,0.6),0 0 50px rgba(168,85,247,0.3)} }
@keyframes rippleOut { from{width:6px;height:6px;opacity:1} to{width:70px;height:70px;opacity:0} }
.fade-up { animation:fadeUp 0.4s ease both; }
.float   { animation:float 3s ease-in-out infinite; }
</style>
""", unsafe_allow_html=True)

# ══════════════════════════════════════════════════════════════════════════════
# VFX CANVAS — particles + matrix + cursor trail + scanlines + click ripples
# ══════════════════════════════════════════════════════════════════════════════
st.markdown("""
<canvas id="vfx" style="position:fixed;top:0;left:0;width:100%;height:100%;
    pointer-events:none;z-index:0;opacity:0.5;"></canvas>
<div id="trail"></div>
<script>
(function(){
    const c=document.getElementById('vfx');
    if(!c)return;
    const x=c.getContext('2d');
    function resize(){c.width=window.innerWidth;c.height=window.innerHeight;}
    resize(); window.addEventListener('resize',resize);
    const N=90,D=140,P=[];
    class Pt{
        constructor(){this.reset();}
        reset(){
            this.x=Math.random()*c.width; this.y=Math.random()*c.height;
            this.vx=(Math.random()-.5)*.5; this.vy=(Math.random()-.5)*.5;
            this.r=Math.random()*2+1; this.t=Math.random()>.7?'p':'c';
            this.a=Math.random()*.6+.3; this.ph=Math.random()*Math.PI*2;
        }
        update(){
            this.x+=this.vx; this.y+=this.vy; this.ph+=.03;
            if(this.x<0||this.x>c.width)this.vx*=-1;
            if(this.y<0||this.y>c.height)this.vy*=-1;
        }
        draw(){
            const g=Math.sin(this.ph)*.3+.7;
            const col=this.t==='c'?`rgba(0,212,255,${this.a*g})`:`rgba(168,85,247,${this.a*g})`;
            x.beginPath(); x.arc(this.x,this.y,this.r*g,0,Math.PI*2);
            x.fillStyle=col; x.shadowColor=this.t==='c'?'#00d4ff':'#a855f7';
            x.shadowBlur=8*g; x.fill(); x.shadowBlur=0;
        }
    }
    for(let i=0;i<N;i++)P.push(new Pt());
    const cols=Math.floor(c.width/22);
    const drops=Array(cols).fill(0).map(()=>Math.random()*-c.height/14);
    const chars='01アイウエオカキクケコ∆∇⬡◈✦◎◉';
    function frame(){
        x.clearRect(0,0,c.width,c.height);
        x.font='12px "Share Tech Mono",monospace';
        for(let i=0;i<cols;i++){
            const ch=chars[Math.floor(Math.random()*chars.length)];
            x.fillStyle=`rgba(0,212,255,${Math.random()*.12})`;
            x.fillText(ch,i*22,drops[i]*14);
            if(drops[i]*14>c.height&&Math.random()>.975)drops[i]=0;
            drops[i]+=.25;
        }
        for(let i=0;i<P.length;i++){
            for(let j=i+1;j<P.length;j++){
                const dx=P[i].x-P[j].x,dy=P[i].y-P[j].y,d=Math.sqrt(dx*dx+dy*dy);
                if(d<D){
                    const a=(1-d/D)*.25;
                    const g=x.createLinearGradient(P[i].x,P[i].y,P[j].x,P[j].y);
                    g.addColorStop(0,`rgba(0,212,255,${a})`);
                    g.addColorStop(1,`rgba(168,85,247,${a})`);
                    x.beginPath(); x.moveTo(P[i].x,P[i].y); x.lineTo(P[j].x,P[j].y);
                    x.strokeStyle=g; x.lineWidth=.5; x.stroke();
                }
            }
        }
        P.forEach(p=>{p.update();p.draw();});
        requestAnimationFrame(frame);
    }
    frame();

    // Cursor trail
    const tr=document.getElementById('trail');
    const dots=[]; const L=18;
    for(let i=0;i<L;i++){
        const d=document.createElement('div');
        const s=(1-i/L)*10+2;
        d.style.cssText=`position:fixed;width:${s}px;height:${s}px;border-radius:50%;
            pointer-events:none;
            background:${i<L/2?'rgba(0,212,255,':'rgba(168,85,247,'}${(1-i/L)*.8});
            box-shadow:0 0 ${s*2}px ${i<L/2?'rgba(0,212,255,0.6)':'rgba(168,85,247,0.6)'};
            transform:translate(-50%,-50%);z-index:9998;`;
        tr.appendChild(d); dots.push({el:d,x:0,y:0});
    }
    let mx=0,my=0;
    document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
    function ut(){
        dots[0].x=mx; dots[0].y=my;
        for(let i=1;i<L;i++){
            dots[i].x+=(dots[i-1].x-dots[i].x)*.45;
            dots[i].y+=(dots[i-1].y-dots[i].y)*.45;
        }
        dots.forEach(d=>{d.el.style.left=d.x+'px';d.el.style.top=d.y+'px';});
        requestAnimationFrame(ut);
    }
    ut();

    // Scanlines
    const sl=document.createElement('div');
    sl.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,212,255,0.015) 2px,rgba(0,212,255,0.015) 4px);';
    document.body.appendChild(sl);

    // Click ripple
    const rs=document.createElement('style');
    rs.textContent='@keyframes rOut{from{width:6px;height:6px;opacity:1}to{width:70px;height:70px;opacity:0}}';
    document.head.appendChild(rs);
    document.addEventListener('click',e=>{
        const r=document.createElement('div');
        r.style.cssText=`position:fixed;left:${e.clientX}px;top:${e.clientY}px;
            width:6px;height:6px;border-radius:50%;
            border:2px solid rgba(0,212,255,0.9);
            transform:translate(-50%,-50%);pointer-events:none;z-index:9999;
            animation:rOut 0.6s ease-out forwards;`;
        document.body.appendChild(r);
        setTimeout(()=>r.remove(),600);
    });
})();
</script>
""", unsafe_allow_html=True)

