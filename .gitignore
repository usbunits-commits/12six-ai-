for k, v in DEFAULTS.items():
    if k not in st.session_state:
        st.session_state[k] = v

def go(p): st.session_state.page = p; st.rerun()
def is_paid(): return st.session_state.tier in ["silver","gold","diamond"]
def rem_min(): return max(0, FREE_TIER_SECONDS - st.session_state.usage_seconds) // 60

# ══════════════════════════════════════════════════════════════════════════════
# MEMORY HELPERS
# ══════════════════════════════════════════════════════════════════════════════
def save_memory(role, text):
    st.session_state.memory.append({"role": role, "text": text})

def get_history():
    return "\n".join([f"{m['role']}: {m['text']}" for m in st.session_state.memory[-10:]])

# ══════════════════════════════════════════════════════════════════════════════
# AI HELPERS
# ══════════════════════════════════════════════════════════════════════════════
def ask_gemini(message):
    try:
        chat = model.start_chat(history=st.session_state.gemini_history)
        res  = chat.send_message(f"{SYSTEM_PROMPT}\n\n{message}")
        st.session_state.gemini_history.append({"role":"user",  "parts":[message]})
        st.session_state.gemini_history.append({"role":"model", "parts":[res.text]})
        if len(st.session_state.gemini_history) > 40:
            st.session_state.gemini_history = st.session_state.gemini_history[-40:]
        return res.text
    except Exception as e:
        return f"⚠️ AI Error: {str(e)}"

def gen_app(desc, tech):
    prompt = f"""You are 12six AI, an elite autonomous developer.
Conversation history: {get_history()}
User request: Build a {tech} application for: {desc}
Return ONLY valid JSON:
{{
    "plan": ["step 1", "step 2", "step 3"],
    "files": {{
        "main.py": "complete file content",
        "requirements.txt": "dependencies",
        "README.md": "setup instructions"
    }}
}}
ALL files must be complete and production-ready. No placeholders."""
    try:
        res  = model.generate_content(prompt)
        text = res.text.strip()
        text = re.sub(r'^\s*```(?:json)?\s*|\s*```\s*$', '', text, flags=re.IGNORECASE)
        data = json.loads(text.strip())
        save_memory("user",  f"Build {tech} app: {desc}")
        save_memory("12six", f"Generated {len(data.get('files',{}))} files")
        return data
    except json.JSONDecodeError:
        return {"plan":["Generation complete"],"files":{"output.txt": res.text}}
    except Exception as e:
        return {"plan":[f"Error: {str(e)}"],"files":{}}

def fix_code_ai(code):
    """Fixed version of ChatGPT's fix_code — proper JSON parsing with regex strip."""
    prompt = f"""You are an expert debugger for 12six AI.
Analyze and fix this code. Be precise and complete.

CODE:
{code}

Reply ONLY in this exact JSON format (no markdown fences):
{{
    "fixed_code": "complete fixed code here",
    "errors_found": ["error 1", "error 2"],
    "explanation": "clear explanation of what was wrong and what was fixed"
}}"""
    try:
        res  = model.generate_content(prompt)
        text = res.text.strip()
        text = re.sub(r'^\s*```(?:json)?\s*|\s*```\s*$', '', text, flags=re.IGNORECASE)
        data = json.loads(text.strip())
        save_memory("user",  f"Debug: {code[:80]}...")
        save_memory("12six", f"Fixed {len(data.get('errors_found',[]))} errors")
        return data
    except Exception as e:
        return {
            "fixed_code":   code,
            "errors_found": [],
            "explanation":  f"Could not parse AI response: {str(e)}"
        }

def eval_code(code, solution, tests):
    prompt = f"""Coding tutor for 12six AI. Evaluate this submission.
Task: {solution}
Tests: {json.dumps(tests)}
Code: ```{code}```
Reply ONLY with JSON (no markdown): {{"correct":true/false,"feedback":"2-3 sentences","hints":["hint if wrong"]}}"""
    try:
        res  = model.generate_content(prompt)
        text = res.text.strip()
        text = re.sub(r'^\s*```(?:json)?\s*|\s*```\s*$', '', text, flags=re.IGNORECASE)
        return json.loads(text.strip())
    except:
        return {"correct":False,"feedback":"Could not evaluate. Try again.","hints":[]}

def safe_run(files):
    """Sandboxed code execution — timeout, path safety, no network."""
    sandbox = "12six_sandbox"
    os.makedirs(sandbox, exist_ok=True)
    for fname, content in files.items():
        safe_name = os.path.basename(fname)
        try:
            with open(os.path.join(sandbox, safe_name), "w", encoding="utf-8") as f:
                f.write(content)
        except Exception as e:
            return {"stdout":"","stderr":f"File write error: {e}","success":False}
    main_path = os.path.join(sandbox, "main.py")
    if not os.path.exists(main_path):
        return {"stdout":"","stderr":"No main.py found.","success":False}
    try:
        result = subprocess.run(
            ["python", main_path],
            capture_output=True, text=True,
            timeout=10, cwd=sandbox,
        )
        return {"stdout":result.stdout,"stderr":result.stderr,"success":result.returncode==0}
    except subprocess.TimeoutExpired:
        return {"stdout":"","stderr":"⏱ Timed out (10s limit).","success":False}
    except FileNotFoundError:
        return {"stdout":"","stderr":"Python not found on this system.","success":False}
    except Exception as e:
        return {"stdout":"","stderr":f"Execution error: {str(e)}","success":False}

