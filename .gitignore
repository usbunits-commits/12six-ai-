# PAGE: COMMUNITY
# ══════════════════════════════════════════════════════════════════════════════
def page_community():
    neon_header("◉ COMMUNITY", "Operator network · Session chat · Connect with builders")

    if not is_paid():
        st.markdown(f"""
        <div style="background:rgba(240,192,96,0.04);border:1px solid rgba(240,192,96,0.15);
                    border-radius:10px;padding:1rem;margin-bottom:1rem;">
            <div style="color:#f0c060;font-family:'Share Tech Mono',monospace;font-size:0.75rem;">
                // FULL REAL-TIME NETWORK REQUIRES SILVER+. SESSION CHAT ACTIVE BELOW.
            </div>
        </div>
        """, unsafe_allow_html=True)

    for msg in st.session_state.community_msgs[-30:]:
        is_me = msg["user"] == st.session_state.user_email.split("@")[0]
        with st.chat_message("user" if is_me else "assistant", avatar="◉" if is_me else "◈"):
            c = "#00d4ff" if is_me else "#00ff88"
            st.markdown(
                f"<span style='color:{c};font-family:\"Share Tech Mono\",monospace;font-size:0.72rem;font-weight:600;'>{msg['user']}</span>"
                f"  <span style='font-family:Rajdhani,sans-serif;font-size:0.95rem;'>{msg['text']}</span>",
                unsafe_allow_html=True
            )

    with st.form("cf", clear_on_submit=True):
        col1, col2 = st.columns([6,1])
        with col1:
            text = st.text_input("Message", placeholder="// Broadcast to network...", label_visibility="collapsed")
        with col2:
            send = st.form_submit_button("SEND", use_container_width=True)
        if send and text.strip():
            st.session_state.community_msgs.append({
                "user": st.session_state.user_email.split("@")[0],
                "text": text.strip()
            })
            st.rerun()

    if st.button("🔄 REFRESH FEED"):
        st.rerun()

