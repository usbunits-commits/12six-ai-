# PAGE: PRICING
# ══════════════════════════════════════════════════════════════════════════════
def page_pricing():
    neon_header("◇ PRICING", "Select your access tier · Upgrade anytime · Cancel anytime")

    PLANS = [
        {"id":"free",   "name":"FREE",    "price":"$0",   "per":"FOREVER",     "color":"#4a6080",
         "feat":[("✦","3 hrs AI/day"),("✦","App Builder"),("✦","Debugger"),("✦","Practice"),
                 ("◦","App Generator ZIP"),("◦","Unlimited chat"),("◦","Community full")]},
        {"id":"silver", "name":"SILVER",  "price":"$20",  "per":"PER MONTH",   "color":"#00d4ff",
         "feat":[("✦","Unlimited AI chat"),("✦","App Generator + ZIP"),("✦","Full community"),
                 ("✦","Chat export"),("✦","All modules"),("✦","Priority support"),("✦","Usage analytics")]},
        {"id":"gold",   "name":"GOLD",    "price":"$100", "per":"PER 6 MONTHS","color":"#f0c060",
         "feat":[("✦","Everything Silver"),("✦","Save 17%"),("✦","Priority AI queue"),
                 ("✦","Early features"),("✦","Email support"),("✦","Extended context")]},
        {"id":"diamond","name":"DIAMOND", "price":"$160", "per":"PER YEAR",    "color":"#c0a0e8",
         "feat":[("✦","Everything Gold"),("✦","Save 33%"),("✦","API access"),
                 ("✦","Custom AI persona"),("✦","1-on-1 onboarding"),("✦","Dedicated support")]},
    ]

    cols = st.columns(4)
    for plan, col in zip(PLANS, cols):
        with col:
            is_cur = st.session_state.tier == plan["id"]
            c  = plan["color"]
            bw = "2px" if is_cur else "1px"
            ba = "" if is_cur else "33"
            gl = f"box-shadow:0 0 30px {c}18,0 0 60px {c}08;" if is_cur else ""

            st.markdown(f"""
            <div style="background:linear-gradient(135deg,rgba(7,13,26,0.98),rgba(4,8,16,0.98));
                        border:{bw} solid {c}{ba};border-radius:14px;padding:1.8rem;{gl}
                        position:relative;overflow:hidden;">
                <div style="position:absolute;top:0;left:0;right:0;height:2px;
                            background:linear-gradient(90deg,transparent,{c},transparent);
                            opacity:{'1' if is_cur else '0.4'};"></div>
                <div style="position:absolute;top:-40px;right:-40px;width:100px;height:100px;
                            background:radial-gradient(circle,{c}0f 0%,transparent 70%);border-radius:50%;"></div>
                <div style="font-family:'Share Tech Mono',monospace;font-size:0.6rem;color:{c}88;
                            letter-spacing:0.15em;margin-bottom:0.3rem;">// TIER</div>
                <div style="font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:800;
                            color:{c};letter-spacing:0.05em;text-shadow:0 0 10px {c}44;
                            margin-bottom:0.8rem;">{plan['name']}</div>
                <div style="font-family:'Orbitron',sans-serif;font-size:2rem;font-weight:900;
                            color:#e2f0ff;line-height:1;">{plan['price']}</div>
                <div style="font-family:'Share Tech Mono',monospace;font-size:0.6rem;color:#4a6080;
                            letter-spacing:0.1em;margin-bottom:1.5rem;">{plan['per']}</div>
                <div style="border-top:1px solid {c}22;padding-top:1rem;">
                    {"".join([f'<div style="color:{"#e2f0ff" if s=="✦" else "#2a3040"};font-family:Rajdhani,sans-serif;font-size:0.9rem;padding:2px 0;"><span style="color:{c if s=="#e2f0ff" or s=="✦" else "#2a3040"};margin-right:6px;">{s}</span>{f}</div>' for s,f in plan['feat']])}
                </div>
            </div>
            """, unsafe_allow_html=True)

            st.markdown("<div style='height:0.5rem'></div>", unsafe_allow_html=True)

            if is_cur:
                st.markdown(f"<div style='text-align:center;color:{c};font-family:\"Share Tech Mono\",monospace;font-size:0.7rem;padding:0.3rem;letter-spacing:0.1em;'>// ACTIVE TIER</div>", unsafe_allow_html=True)
            elif plan["id"] != "free":
                if st.button(f"ACTIVATE {plan['name']}", key=f"buy_{plan['id']}", use_container_width=True, type="primary"):
                    st.session_state.tier = plan["id"]
                    st.success(f"// {plan['name']} access granted.")
                    time.sleep(0.8)
                    st.rerun()

    st.markdown("""
    <div style="text-align:center;color:#2a3040;font-family:'Share Tech Mono',monospace;
                font-size:0.65rem;letter-spacing:0.08em;margin-top:2rem;padding-top:1rem;
                border-top:1px solid rgba(0,212,255,0.06);">
        // PAYMENTS VIA SKYDO · USD & INR · SSL SECURED · CANCEL ANYTIME
    </div>
    """, unsafe_allow_html=True)

# ══════════════════════════════════════════════════════════════════════════════
# PAGE: PROFILE
# ══════════════════════════════════════════════════════════════════════════════
def page_profile():
    neon_header("⊕ PROFILE", "Operator status · System overview · Account management")

    col1, col2 = st.columns([1, 2])
    tc_map = {"free":"#4a6080","silver":"#00d4ff","gold":"#f0c060","diamond":"#c0a0e8"}
    tc   = tc_map.get(st.session_state.tier, "#4a6080")
    name = st.session_state.user_email.split("@")[0]

    with col1:
        st.markdown(f"""
        <div style="background:linear-gradient(135deg,rgba(7,13,26,0.98),rgba(4,8,16,0.98));
                    border:1px solid {tc}33;border-radius:14px;padding:2rem;text-align:center;
                    box-shadow:0 0 30px {tc}0f;position:relative;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;right:0;height:1px;
                        background:linear-gradient(90deg,transparent,{tc},transparent);"></div>
            <div style="width:68px;height:68px;
                        background:linear-gradient(135deg,{tc}22,{tc}44);
                        border:2px solid {tc}88;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;
                        margin:0 auto 1rem;font-family:'Orbitron',sans-serif;
                        font-size:1.5rem;font-weight:900;color:{tc};
                        box-shadow:0 0 20px {tc}44;text-shadow:0 0 10px {tc};">{name[0].upper()}</div>
            <div style="font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.95rem;
                        color:#e2f0ff;letter-spacing:0.05em;">{name.upper()}</div>
            <div style="font-size:0.65rem;color:#4a6080;font-family:'Share Tech Mono',monospace;
                        margin:0.3rem 0 0.8rem;word-break:break-all;">{st.session_state.user_email}</div>
            <span style="background:{tc}18;border:1px solid {tc}44;color:{tc};font-size:0.6rem;
                         padding:2px 10px;border-radius:20px;font-family:'Share Tech Mono',monospace;
                         letter-spacing:0.1em;text-transform:uppercase;
                         box-shadow:0 0 8px {tc}30;">{st.session_state.tier.upper()} OPERATOR</span>
            <div style="color:#00ff88;font-size:0.6rem;font-family:'Share Tech Mono',monospace;
                        letter-spacing:0.12em;text-transform:uppercase;margin-top:0.8rem;">● ONLINE</div>
        </div>
        """, unsafe_allow_html=True)

    with col2:
        section_label("DAILY USAGE")
        used = st.session_state.usage_seconds
        pct  = min(used / FREE_TIER_SECONDS, 1.0)
        bc   = "#ff4466" if pct > .8 else "#f0c060" if pct > .5 else "#00d4ff"
        st.progress(pct)
        st.markdown(f"<div style='color:{bc};font-family:\"Share Tech Mono\",monospace;font-size:0.72rem;'>// {used//60}/{FREE_TIER_SECONDS//60} MINUTES — {rem_min()} REMAINING</div>", unsafe_allow_html=True)

        st.markdown("<div style='height:1.2rem'></div>", unsafe_allow_html=True)
        section_label("SYSTEM STATS")

        ca,cb,cc,cd,ce = st.columns(5)
        ca.metric("MESSAGES",    len(st.session_state.chat_messages))
        cb.metric("EXERCISES",   len(st.session_state.completed))
        cc.metric("PROJ FILES",  len(st.session_state.project_files))
        cd.metric("MEMORY LOGS", len(st.session_state.memory))
        ce.metric("COMMUNITY",   len([m for m in st.session_state.community_msgs
                                      if m["user"] == name]))

        st.markdown("<div style='height:1rem'></div>", unsafe_allow_html=True)

        col_a, col_b = st.columns(2)
        with col_a:
            if st.session_state.tier == "free":
                if st.button("◇ UPGRADE ACCESS TIER", use_container_width=True, type="primary"):
                    go("pricing")
        with col_b:
            if st.button("⊘ TERMINATE SESSION", use_container_width=True):
                for k, v in DEFAULTS.items():
                    st.session_state[k] = v
                st.rerun()

# ══════════════════════════════════════════════════════════════════════════════
# PAGE: MEMORY (ChatGPT's memory page — fully styled)
# ══════════════════════════════════════════════════════════════════════════════
def page_memory():
    neon_header("🧠 MEMORY", "Full AI conversation log · Session history · Activity tracker")

    col1, col2, col3 = st.columns([2,1,1])
    with col1:
        st.markdown(f"<div style='color:#00d4ff;font-family:\"Share Tech Mono\",monospace;font-size:0.75rem;'>// {len(st.session_state.memory)} ENTRIES LOGGED</div>", unsafe_allow_html=True)
    with col2:
        if st.button("⊘ CLEAR MEMORY", use_container_width=True):
            st.session_state.memory = []
            st.rerun()
    with col3:
        if st.session_state.memory:
            mem_export = "\n\n".join([f"[{m['role'].upper()}]\n{m['text']}" for m in st.session_state.memory])
            st.download_button("EXPORT LOG", mem_export, "12six-memory.txt", "text/plain", use_container_width=True)

    st.markdown("<div style='height:0.5rem'></div>", unsafe_allow_html=True)

    if not st.session_state.memory:
        st.markdown(f"""
        <div style="background:rgba(0,212,255,0.04);border:1px solid rgba(0,212,255,0.1);
                    border-radius:10px;padding:2rem;text-align:center;">
            <div style="font-family:'Orbitron',sans-serif;color:#4a6080;font-size:0.8rem;">// MEMORY BANKS EMPTY</div>
            <div style="color:#4a6080;font-family:'Rajdhani',sans-serif;font-size:0.85rem;margin-top:0.3rem;">
                Use App Builder, Debugger, or Chat to populate memory.
            </div>
        </div>
        """, unsafe_allow_html=True)
        return

    # Filter
    filter_role = st.selectbox("// Filter by", ["All","user","12six"], key="mem_filter")
    entries = st.session_state.memory if filter_role == "All" else [m for m in st.session_state.memory if m["role"] == filter_role]

    for m in reversed(entries):
        is_user = m["role"] == "user"
        c     = "#00d4ff" if is_user else "#00ff88"
        label = "OPERATOR" if is_user else "12SIX AI"
        st.markdown(f"""
        <div style="background:rgba(7,13,26,0.8);border:1px solid {c}22;border-radius:8px;
                    padding:0.8rem 1rem;margin-bottom:0.5rem;">
            <div style="color:{c};font-family:'Share Tech Mono',monospace;font-size:0.65rem;
                        letter-spacing:0.1em;margin-bottom:0.3rem;">// {label}</div>
            <div style="color:#e2f0ff;font-family:'Rajdhani',sans-serif;font-size:0.9rem;
                        line-height:1.5;">{m['text']}</div>
        </div>
        """, unsafe_allow_html=True)

# ══════════════════════════════════════════════════════════════════════════════
# MAIN ROUTER
# ══════════════════════════════════════════════════════════════════════════════
def main():
    if not st.session_state.get("logged_in", False):
        page_login()
        return

    render_sidebar()

    routes = {
        "dashboard": page_dashboard,
        "chat":      page_chat,
        "builder":   page_builder,
        "runner":    page_runner,
        "debugger":  page_debugger,
        "generator": page_generator,
        "learn":     page_learn,
        "community": page_community,
        "pricing":   page_pricing,
        "profile":   page_profile,
        "memory":    page_memory,
    }
    routes.get(st.session_state.page, page_dashboard)()

main()
