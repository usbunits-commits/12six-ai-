# PAGE: APP GENERATOR (paid, ZIP download)
# ══════════════════════════════════════════════════════════════════════════════
def page_generator():
    neon_header("⬡ APP GENERATOR", "Natural language → full codebase + ZIP · Silver+ required")

    if not is_paid():
        locked_banner(
            "MODULE LOCKED — SILVER+ REQUIRED",
            "The App Generator with ZIP download requires Silver or higher. "
            "Use the free AI App Builder for project generation without tier restrictions.",
        )
        if st.button("⬢ USE FREE APP BUILDER INSTEAD", use_container_width=True):
            go("builder")
        return

    description = st.text_area("// Describe your application", height=140,
        placeholder="e.g. A real-time collaborative todo app with auth, PostgreSQL, drag-and-drop, React")

    col1, col2 = st.columns(2)
    with col1:
        tech = st.selectbox("// Tech Stack", [
            "React + Node.js","React + FastAPI","Next.js + TypeScript",
            "Python Flask","Django + Vue.js","MERN Stack","Streamlit App","Flutter Mobile",
        ])
    with col2:
        st.markdown("<div style='height:1.9rem'></div>", unsafe_allow_html=True)
        gen_btn = st.button("⬡ GENERATE APPLICATION", use_container_width=True, type="primary")

    if gen_btn and description.strip():
        with st.spinner("// Compiling application..."):
            data = gen_app(description, tech)
        files = data.get("files", {})
        if files:
            st.session_state.project_files = files
            st.success(f"// {len(files)} files generated.")
            buf = io.BytesIO()
            with zipfile.ZipFile(buf,"w",zipfile.ZIP_DEFLATED) as z:
                for n, c in files.items(): z.writestr(n, c)
            st.download_button("⬇ DOWNLOAD ZIP", buf.getvalue(), "12six-app.zip", "application/zip", use_container_width=True)
            with st.expander(f"// PREVIEW — {len(files)} FILES"):
                for fname, content in list(files.items())[:5]:
                    st.markdown(f"**`{fname}`**")
                    st.code(content[:2000], language=fname.split(".")[-1] if "." in fname else "text")
        else:
            st.error("// Generation failed. Try rephrasing.")

