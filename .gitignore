# PAGE: PRACTICE / LEARN (ChatGPT's render_practice — fully built out)
# ══════════════════════════════════════════════════════════════════════════════
def page_learn():
    neon_header("◎ PRACTICE", "Interactive coding exercises · AI-powered evaluation · Track progress")

    done  = len(st.session_state.completed)
    total = len(SAMPLE_EXERCISES)
    pct   = done / total if total > 0 else 0

    col_prog, col_stat = st.columns([3,1])
    with col_prog:
        st.progress(pct)
    with col_stat:
        st.markdown(f"<div style='color:#00d4ff;font-family:\"Share Tech Mono\",monospace;font-size:0.8rem;padding-top:0.3rem;'>{done}/{total} complete</div>", unsafe_allow_html=True)

    st.markdown("<div style='height:0.5rem'></div>", unsafe_allow_html=True)

    col1, col2 = st.columns(2)
    with col1: lang = st.selectbox("// Language",   ["All","Python","JavaScript","SQL"])
    with col2: diff = st.selectbox("// Difficulty", ["All","beginner","intermediate","advanced"])

    filtered = [e for e in SAMPLE_EXERCISES if
        (lang == "All" or e["language"] == lang) and
        (diff == "All" or e["difficulty"] == diff)]

    if not filtered:
        st.info("// No exercises match your filters.")
        return

    diff_c = {"beginner":"#00d4ff","intermediate":"#f0c060","advanced":"#ff4466"}
    diff_s = {"beginner":"○","intermediate":"◎","advanced":"●"}
    titles = [
        f"{'✦ ' if e['id'] in st.session_state.completed else ''}{diff_s.get(e['difficulty'],'-')} {e['title']} — {e['language']}"
        for e in filtered
    ]

    ex = filtered[titles.index(st.selectbox("// Select exercise", titles))]
    dc = diff_c.get(ex["difficulty"], "#00d4ff")

    st.markdown("<div style='height:0.5rem'></div>", unsafe_allow_html=True)
    col1, col2 = st.columns([1,1])

    with col1:
        st.markdown(f"""
        <div style="background:linear-gradient(135deg,rgba(7,13,26,0.95),rgba(4,8,16,0.95));
                    border:1px solid {dc}22;border-radius:12px;padding:1.5rem;position:relative;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;right:0;height:1px;
                        background:linear-gradient(90deg,transparent,{dc}88,transparent);"></div>
            <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:1rem;">
                <div style="font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:700;color:{dc};
                            text-shadow:0 0 8px {dc}66;">{ex['title']}</div>
                <span style="background:{dc}15;border:1px solid {dc}44;color:{dc};font-size:0.6rem;
                             padding:1px 8px;border-radius:20px;font-family:'Share Tech Mono',monospace;
                             text-transform:uppercase;letter-spacing:0.08em;">{ex['difficulty']}</span>
            </div>
            <div style="color:#4a6080;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;
                        font-family:'Share Tech Mono',monospace;margin-bottom:0.5rem;">// OBJECTIVE</div>
            <div style="color:#e2f0ff;font-family:'Rajdhani',sans-serif;font-size:0.95rem;
                        line-height:1.6;">{ex['description']}</div>
            {'<div style="margin-top:0.8rem;color:#00ff88;font-family:Share Tech Mono,monospace;font-size:0.7rem;">// ✦ MODULE COMPLETE</div>' if ex["id"] in st.session_state.completed else ""}
        </div>
        """, unsafe_allow_html=True)
        if ex.get("starter_code"):
            st.markdown("<div style='height:0.5rem'></div>", unsafe_allow_html=True)
            st.code(ex["starter_code"], language=ex["language"].lower())

    with col2:
        user_code = st.text_area("// Your solution",
            value=ex.get("starter_code",""), height=250,
            label_visibility="collapsed", key=f"code_{ex['id']}")

        col_a, col_b, col_c = st.columns(3)
        with col_a:
            check = st.button("✦ EVALUATE", use_container_width=True, type="primary", key=f"chk_{ex['id']}")
        with col_b:
            hint = st.button("// HINT", use_container_width=True, key=f"hnt_{ex['id']}")
        with col_c:
            debug = st.button("🐞 DEBUG", use_container_width=True, key=f"dbg_{ex['id']}")

        if check:
            with st.spinner("// Evaluating..."):
                result = eval_code(user_code, ex["solution"], ex.get("test_cases") or {})
            if result["correct"]:
                st.balloons()
                st.success(f"✦ CORRECT — {result['feedback']}")
                st.session_state.completed.add(ex["id"])
            else:
                st.error(result["feedback"])
                if result.get("hints"):
                    with st.expander("// HINTS"):
                        for h in result["hints"]:
                            st.markdown(f"◦ {h}")

        if hint:
            with st.spinner(""):
                h = ask_gemini(
                    f"Give me ONE short hint (no solution) for: {ex['description']}. "
                    f"My code: {user_code}. Max 2 sentences."
                )
            st.info(f"// {h}")

        if debug:
            with st.spinner("// Debugging your solution..."):
                fix = fix_code_ai(user_code)
            section_label("DEBUGGED VERSION", "#00ff88")
            st.code(fix.get("fixed_code", user_code), language="python")
            if fix.get("explanation"):
                st.caption(fix["explanation"])

